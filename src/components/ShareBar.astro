---
import Icon from './Icon.astro';
interface Props {
  url: string;   // absolute URL
  title: string;
}
const { url, title } = Astro.props;
const linkedin = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---
<div class="share" data-url={url} data-title={title}>
  <span class="share-label mono-label">Share</span>
  <button class="share-btn" type="button" data-share="copy" aria-label="Copy link">
    <span class="share-ico-default"><Icon name="link" size={16} /></span>
    <span class="share-ico-done"><Icon name="check" size={16} /></span>
    <span class="share-txt">Copy link</span>
  </button>
  <button class="share-btn share-icononly" type="button" data-share="native" aria-label="Share">
    <Icon name="share" size={16} />
  </button>
  <a class="share-btn share-icononly" href={linkedin} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
    <span class="share-li">in</span>
  </a>
</div>

<script>
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-share]');
    if (!btn) return;
    const box = btn.closest('.share') as HTMLElement | null;
    if (!box) return;
    const url = box.dataset.url || location.href;
    const title = box.dataset.title || document.title;
    const action = (btn as HTMLElement).dataset.share;

    if (action === 'copy') {
      try { await navigator.clipboard.writeText(url); } catch {}
      btn.classList.add('is-done');
      const txt = btn.querySelector('.share-txt');
      const prev = txt?.textContent;
      if (txt) txt.textContent = 'Copied';
      setTimeout(() => { btn.classList.remove('is-done'); if (txt && prev) txt.textContent = prev; }, 1600);
    } else if (action === 'native') {
      if (navigator.share) { try { await navigator.share({ title, url }); } catch {} }
      else { try { await navigator.clipboard.writeText(url); } catch {} }
    }
  });
</script>

<style>
  .share { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .share-label { margin-right: 0.1rem; }
  .share-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--mono); font-size: var(--t-xs); color: var(--ink-soft);
    background: var(--card); border: 1px solid var(--line-strong);
    border-radius: 999px; padding: 0.4rem 0.7rem; cursor: pointer; text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .share-btn:hover { border-color: var(--ink-soft); color: var(--ink); }
  .share-icononly { padding: 0.4rem; }
  .share-li { font-family: var(--mono); font-weight: 600; font-size: 0.78rem; line-height: 1; padding: 0 0.1rem; }
  .share-ico-done, .share-btn.is-done .share-ico-default { display: none; }
  .share-btn.is-done { color: var(--teal); border-color: color-mix(in srgb, var(--teal) 45%, var(--line-strong)); }
  .share-btn.is-done .share-ico-done { display: inline-flex; color: var(--teal); }
</style>
