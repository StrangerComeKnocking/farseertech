---
import CopyQuoteButton from './CopyQuoteButton.astro';
interface Props { quote: string; accent?: string }
const { quote, accent = 'var(--coral)' } = Astro.props;
---
<figure class="qcard" style={`--accent:${accent}`}>
  <p class="mono-label qcard-label">Pull quote</p>
  <blockquote class="qcard-quote">{quote}</blockquote>
  <CopyQuoteButton text={quote} class="qcard-copy" />
</figure>

<style>
  .qcard {
    position: relative;
    margin: 0;
    padding: 0.95rem 1rem 1rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--r) var(--r) 0;
  }
  .qcard-label { color: color-mix(in srgb, var(--accent) 60%, var(--ink-soft)); }
  .qcard-quote {
    margin: 0.4rem 0 0;
    font-family: var(--serif);
    font-size: 1.06rem;
    font-style: italic;
    line-height: 1.4;
    color: #34333d;
  }
  .qcard :global(.qcard-copy) { margin-top: 0.7rem; }
</style>
