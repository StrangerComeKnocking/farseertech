---
import { SITE, NAV } from '../consts';
import Icon from './Icon.astro';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<header class="hdr">
  <div class="hdr-in container">
    <a class="brand" href="/" aria-label={`${SITE.title} — home`}>
      <Icon name="farseer" size={30} class="brand-mark" />
      <span class="brand-word">{SITE.title}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>

    <button class="search-btn" type="button" data-search-open aria-label="Search (press /)">
      <Icon name="search" size={17} />
      <span class="search-btn-label">Search</span>
      <kbd>/</kbd>
    </button>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 90;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(135%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .hdr-in {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 2.5vw, 1.8rem);
    min-height: 4rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
    margin-right: auto;
  }
  .brand-mark { color: var(--ink); }
  .brand:hover .brand-mark { color: var(--coral); transition: color 0.2s ease; }
  .brand-word {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.32rem;
    letter-spacing: -0.02em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 1.8vw, 1.5rem);
  }
  .nav a {
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 2px;
    border-bottom: 1.5px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .nav a:hover { color: var(--ink); }
  .nav a.active { color: var(--ink); border-bottom-color: var(--coral); }

  .search-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
    background: var(--card);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .search-btn:hover { border-color: var(--ink-soft); color: var(--ink); }
  .search-btn kbd {
    font-family: var(--mono);
    font-size: 0.7rem;
    line-height: 1;
    padding: 0.18rem 0.36rem;
    border: 1px solid var(--line-strong);
    border-radius: 5px;
    color: var(--faint);
    background: var(--paper);
  }

  @media (max-width: 53rem) {
    .nav {
      order: 3;
      flex-basis: 100%;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .nav::-webkit-scrollbar { display: none; }
    .search-btn-label { display: none; }
  }
</style>
