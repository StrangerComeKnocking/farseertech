---
import Icon from './Icon.astro';
import { getPublishedPosts, postUrl, postReadingTime } from '../utils/posts';
import { PILLARS } from '../consts';

const posts = await getPublishedPosts();
const index = posts.map((p) => ({
  title: p.data.title,
  desc: p.data.description,
  pillar: PILLARS[p.data.pillar].short,
  accent: PILLARS[p.data.pillar].accentHex,
  time: postReadingTime(p),
  url: postUrl(p),
}));
---
<div class="cmd" id="cmd" hidden>
  <div class="cmd-backdrop" data-search-close></div>
  <div class="cmd-panel" role="dialog" aria-modal="true" aria-label="Search FarseerTech">
    <div class="cmd-row">
      <Icon name="search" size={18} class="cmd-search-icon" />
      <input id="cmd-input" type="text" autocomplete="off" spellcheck="false"
        placeholder="Search field notes, pillars, ideas…" aria-label="Search" />
      <kbd>esc</kbd>
    </div>
    <ul id="cmd-results" class="cmd-results" role="listbox" aria-label="Results"></ul>
    <p id="cmd-empty" class="cmd-empty" hidden>No matches — try a broader term.</p>
  </div>
</div>

<script define:vars={{ index }}>
  const root = document.getElementById('cmd');
  const input = document.getElementById('cmd-input');
  const list = document.getElementById('cmd-results');
  const empty = document.getElementById('cmd-empty');
  let active = 0;
  let current = [];

  const esc = (s) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

  function search(q) {
    q = q.trim().toLowerCase();
    if (!q) return index.slice(0, 6);
    return index
      .map((it) => {
        const hay = (it.title + ' ' + it.desc + ' ' + it.pillar).toLowerCase();
        let score = 0;
        if (it.title.toLowerCase().includes(q)) score += 3;
        if (it.pillar.toLowerCase().includes(q)) score += 2;
        if (hay.includes(q)) score += 1;
        return { it, score };
      })
      .filter((r) => r.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 8)
      .map((r) => r.it);
  }

  function render() {
    current = search(input.value);
    active = 0;
    if (!current.length) {
      list.innerHTML = '';
      empty.hidden = false;
      return;
    }
    empty.hidden = true;
    list.innerHTML = current
      .map(
        (it, i) => `<li role="option" aria-selected="${i === 0}" class="cmd-item${i === 0 ? ' is-active' : ''}" data-i="${i}">
          <a href="${it.url}">
            <span class="cmd-bar" style="background:${it.accent}"></span>
            <span class="cmd-text">
              <span class="cmd-title">${esc(it.title)}</span>
              <span class="cmd-meta">${esc(it.pillar)} · ${esc(it.time)}</span>
            </span>
          </a></li>`
      )
      .join('');
  }

  function setActive(n) {
    const items = [...list.querySelectorAll('.cmd-item')];
    if (!items.length) return;
    active = (n + items.length) % items.length;
    items.forEach((el, i) => {
      el.classList.toggle('is-active', i === active);
      el.setAttribute('aria-selected', i === active);
    });
    items[active].scrollIntoView({ block: 'nearest' });
  }

  function open() {
    root.hidden = false;
    document.body.style.overflow = 'hidden';
    input.value = '';
    render();
    requestAnimationFrame(() => input.focus());
  }
  function close() {
    root.hidden = true;
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    if (e.target.closest('[data-search-open]')) { e.preventDefault(); open(); }
    else if (e.target.closest('[data-search-close]')) close();
  });

  document.addEventListener('keydown', (e) => {
    const typing = /^(INPUT|TEXTAREA|SELECT)$/.test(document.activeElement?.tagName) ||
      document.activeElement?.isContentEditable;
    if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) { e.preventDefault(); root.hidden ? open() : close(); return; }
    if (e.key === '/' && !typing && root.hidden) { e.preventDefault(); open(); return; }
    if (root.hidden) return;
    if (e.key === 'Escape') { e.preventDefault(); close(); }
    else if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
    else if (e.key === 'Enter') {
      const link = list.querySelectorAll('.cmd-item')[active]?.querySelector('a');
      if (link) window.location.href = link.getAttribute('href');
    }
  });

  input?.addEventListener('input', render);
</script>

<style>
  .cmd { position: fixed; inset: 0; z-index: 300; display: grid; place-items: start center; }
  .cmd[hidden] { display: none; }
  .cmd-backdrop { position: absolute; inset: 0; background: rgba(38, 37, 45, 0.32); backdrop-filter: blur(3px); }
  .cmd-panel {
    position: relative;
    margin-top: 12vh;
    width: min(40rem, 92vw);
    background: var(--card);
    border: 1px solid var(--line-strong);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    animation: cmd-in 0.14s ease;
  }
  @keyframes cmd-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }
  .cmd-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.9rem 1rem; border-bottom: 1px solid var(--line); }
  .cmd-search-icon { color: var(--faint); flex: none; }
  #cmd-input {
    flex: 1; border: none; background: none; outline: none;
    font-family: var(--serif); font-size: 1.15rem; color: var(--ink);
  }
  .cmd-row kbd {
    font-family: var(--mono); font-size: 0.68rem; color: var(--faint);
    border: 1px solid var(--line-strong); border-radius: 5px; padding: 0.15rem 0.35rem;
  }
  .cmd-results { list-style: none; padding: 0.4rem; margin: 0; max-height: 56vh; overflow-y: auto; }
  .cmd-item a {
    display: flex; align-items: stretch; gap: 0.7rem;
    padding: 0.6rem 0.6rem; border-radius: var(--r-sm); text-decoration: none; color: var(--ink);
  }
  .cmd-item.is-active a { background: color-mix(in srgb, var(--indigo) 9%, transparent); }
  .cmd-bar { width: 3px; border-radius: 3px; flex: none; }
  .cmd-text { display: flex; flex-direction: column; gap: 0.15rem; }
  .cmd-title { font-family: var(--serif); font-size: 1.02rem; line-height: 1.2; }
  .cmd-meta { font-family: var(--mono); font-size: var(--t-2xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--faint); }
  .cmd-empty { padding: 1.2rem 1rem; font-family: var(--mono); font-size: var(--t-sm); color: var(--faint); }
</style>
