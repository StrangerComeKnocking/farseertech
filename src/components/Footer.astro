---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="ft">
  <span class="ft-copy">© {year} {SITE.owner} · {SITE.title}</span>
  <span class="ft-links">
    <a href="/about">About</a>
  </span>
</footer>

<style>
  .ft {
    flex: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    padding: 1.5rem clamp(1.4rem, 5vw, 3.5rem);
    margin-top: 2.5rem;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    color: var(--faint);
  }
  .ft-links { display: flex; gap: 1.2rem; }
  .ft-links a { color: var(--ink-soft); text-decoration: none; }
  .ft-links a:hover { color: var(--coral); }
</style>
