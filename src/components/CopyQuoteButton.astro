---
// Markup-only. Click handling + confirmation is delegated globally by the
// SectionReader script (which also enhances in-body blockquotes the same way).
import Icon from './Icon.astro';
interface Props { text: string; class?: string }
const { text, class: className } = Astro.props;
---
<button class:list={['quote-copy', className]} type="button" data-copy={text} aria-label="Copy quote">
  <span class="qc-default"><Icon name="copy" size={15} /></span>
  <span class="qc-done"><Icon name="check" size={15} /></span>
</button>
