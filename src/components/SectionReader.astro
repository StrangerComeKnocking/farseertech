---
import Icon from './Icon.astro';
interface Props {
  sections: string[];
}
const { sections } = Astro.props;
---
<div class="reader" data-reader>
  <aside class="reader-rail">
    <p class="mono-label rail-h">Sections</p>
    <ol class="rail-list">
      {sections.map((t, i) => (
        <li>
          <button class="rail-item" data-go={i} type="button">
            <span class="rail-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="rail-text">{t}</span>
          </button>
        </li>
      ))}
    </ol>
  </aside>

  <div class="reader-main">
    <div class="reader-progress" aria-hidden="true"><span data-bar></span></div>
    <div class="reader-body prose"><slot /></div>
    <nav class="reader-controls" aria-label="Section navigation">
      <button class="rc-btn" data-prev type="button"><Icon name="arrow-left" size={16} />Previous</button>
      <span class="rc-counter mono-label" data-counter aria-live="polite"></span>
      <button class="rc-btn" data-next type="button">Next<Icon name="arrow-right" size={16} /></button>
    </nav>
  </div>

  <aside class="reader-meta"><slot name="meta" /></aside>
</div>

<script>
  const reader = document.querySelector('[data-reader]');
  if (reader) {
    const body = reader.querySelector('.reader-body');
    const sections = body ? [...body.querySelectorAll(':scope > section')] : [];

    if (sections.length > 1) {
      reader.classList.add('is-enhanced');
      const railItems = [...reader.querySelectorAll('.rail-item')] as HTMLElement[];
      const counter = reader.querySelector('[data-counter]');
      const bar = reader.querySelector('[data-bar]') as HTMLElement | null;
      const prevBtn = reader.querySelector('[data-prev]') as HTMLButtonElement | null;
      const nextBtn = reader.querySelector('[data-next]') as HTMLButtonElement | null;
      const main = reader.querySelector('.reader-main') as HTMLElement | null;
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const N = sections.length;
      let cur = 0;

      const go = (n: number, scroll = true) => {
        cur = Math.max(0, Math.min(N - 1, n));
        sections.forEach((s, i) => s.classList.toggle('is-current', i === cur));
        railItems.forEach((b, i) => {
          const on = i === cur;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-current', on ? 'step' : 'false');
        });
        if (counter) counter.textContent = `${String(cur + 1).padStart(2, '0')} / ${String(N).padStart(2, '0')}`;
        if (bar) bar.style.width = `${((cur + 1) / N) * 100}%`;
        if (prevBtn) prevBtn.disabled = cur === 0;
        if (nextBtn) nextBtn.disabled = cur === N - 1;
        if (scroll && main) {
          const top = main.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: reduce ? 'auto' : 'smooth' });
        }
      };

      railItems.forEach((b) => b.addEventListener('click', () => go(Number(b.dataset.go))));
      prevBtn?.addEventListener('click', () => go(cur - 1));
      nextBtn?.addEventListener('click', () => go(cur + 1));
      document.addEventListener('keydown', (e) => {
        const ae = document.activeElement;
        const typing = ae ? /^(INPUT|TEXTAREA|SELECT)$/.test(ae.tagName) : false;
        const searchOpen = !document.getElementById('cmd')?.hidden;
        if (typing || searchOpen) return;
        if (e.key === 'ArrowRight') { e.preventDefault(); go(cur + 1); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); go(cur - 1); }
      });
      go(0, false);
    }

    // Enhance in-body blockquotes with a copy button
    reader.querySelectorAll('.reader-body blockquote').forEach((bq) => {
      if (bq.querySelector('.quote-copy')) return;
      const text = (bq.textContent || '').trim();
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'quote-copy';
      btn.setAttribute('aria-label', 'Copy quote');
      btn.dataset.copy = text;
      btn.innerHTML =
        '<span class="qc-default"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2.5"/><path d="M5 15.5V6A2.5 2.5 0 0 1 7.5 3.5H15"/></svg></span>' +
        '<span class="qc-done"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5L10 17.5L19 7"/></svg></span>';
      bq.appendChild(btn);
    });
  }

  // Global copy delegation (QuoteCard + injected in-body buttons)
  document.addEventListener('click', async (e) => {
    const t = e.target;
    if (!(t instanceof Element)) return;
    const b = t.closest('[data-copy]');
    if (!b) return;
    try { await navigator.clipboard.writeText(b.getAttribute('data-copy') || ''); } catch {}
    b.classList.add('is-done');
    setTimeout(() => b.classList.remove('is-done'), 1500);
  });
</script>

<style>
  .reader {
    display: grid;
    grid-template-columns: 12.5rem minmax(0, 1fr) 14rem;
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: start;
  }
  .reader-rail, .reader-meta { position: sticky; top: 5.2rem; }

  .rail-h { margin-bottom: 0.7rem; }
  .rail-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .rail-item {
    display: flex; align-items: baseline; gap: 0.55rem; width: 100%; text-align: left;
    background: none; border: none; cursor: pointer;
    padding: 0.4rem 0.5rem; border-radius: var(--r-sm);
    font-family: var(--serif); font-size: 0.96rem; color: var(--ink-soft);
    border-left: 2px solid transparent;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .rail-item:hover { background: var(--card); color: var(--ink); }
  .rail-item.is-active { color: var(--ink); border-left-color: var(--coral); background: var(--card); }
  .rail-num { font-family: var(--mono); font-size: 0.66rem; color: var(--faint); }
  .rail-item.is-active .rail-num { color: var(--coral); }

  .reader-progress { height: 2px; background: var(--line); border-radius: 2px; margin-bottom: 1.6rem; overflow: hidden; }
  .reader-progress span { display: block; height: 100%; width: 0; background: var(--coral); transition: width 0.25s ease; }
  .reader:not(.is-enhanced) .reader-progress { display: none; }

  .reader-controls {
    display: none;
    align-items: center; justify-content: space-between;
    gap: 1rem; margin-top: 2rem; padding-top: 1.2rem; border-top: 1px solid var(--line);
  }
  .reader.is-enhanced .reader-controls { display: flex; }
  .rc-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--mono); font-size: var(--t-sm); color: var(--ink);
    background: var(--card); border: 1px solid var(--line-strong); border-radius: 999px;
    padding: 0.5rem 0.9rem; cursor: pointer;
    transition: border-color 0.15s ease, opacity 0.15s ease;
  }
  .rc-btn:hover:not(:disabled) { border-color: var(--ink); }
  .rc-btn:disabled { opacity: 0.35; cursor: default; }

  .reader-meta { display: flex; flex-direction: column; gap: 1.1rem; }

  /* Without JS, hide the rail (its buttons are inert); article reads linearly. */
  .reader:not(.is-enhanced) .reader-rail { display: none; }

  @media (max-width: 60rem) {
    .reader { grid-template-columns: 1fr; }
    .reader-rail { display: none; }
    .reader-meta { position: static; order: 3; }
  }
</style>
