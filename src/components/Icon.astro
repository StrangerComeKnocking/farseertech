---
// Authored monoline icon set (see docs/guidelines/icons.md).
// 24x24 by default, 2px stroke, rounded, currentColor + restrained accent marks.
interface Props {
  name: string;
  size?: number;
  label?: string;     // when set, the icon is announced; otherwise decorative
  class?: string;
}
const { name, size = 24, label, class: className } = Astro.props;

const ICONS: Record<string, { vb: string; body: string }> = {
  farseer: {
    vb: '0 0 32 32',
    body: `<path d="M3.5 16C6.8 10.8 11 8.2 16 8.2C21 8.2 25.2 10.8 28.5 16C25.2 21.2 21 23.8 16 23.8C11 23.8 6.8 21.2 3.5 16Z" stroke-linejoin="round"/><circle cx="16" cy="16" r="4.2"/><path d="M7 26H25"/><circle cx="23.5" cy="8.5" r="2" fill="#f5634f" stroke="none"/>`,
  },
  'field-notes': {
    vb: '0 0 24 24',
    body: `<path d="M7 3H17C18.1 3 19 3.9 19 5V21L16 19.5L13 21L10 19.5L7 21L5 20V5C5 3.9 5.9 3 7 3Z" stroke-linejoin="round"/><path d="M9 8H15"/><path d="M9 12H14" stroke="#f5634f"/>`,
  },
  'building-organizations': {
    vb: '0 0 24 24',
    body: `<circle cx="12" cy="5" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M12 7.5V11.5"/><path d="M12 11.5L6 15.5"/><path d="M12 11.5L18 15.5" stroke="#15a99b"/>`,
  },
  'building-product': {
    vb: '0 0 24 24',
    body: `<rect x="4" y="5" width="16" height="14" rx="3"/><path d="M8 9H16"/><path d="M8 13H12" stroke="#5f6ff0"/><circle cx="17" cy="16" r="1.5" fill="#f5634f" stroke="none"/>`,
  },
  'building-software': {
    vb: '0 0 24 24',
    body: `<rect x="4" y="4" width="6" height="6" rx="1.5"/><rect x="14" y="4" width="6" height="6" rx="1.5"/><rect x="9" y="14" width="6" height="6" rx="1.5"/><path d="M10 7H14"/><path d="M7 10L10.5 14" stroke="#5f6ff0"/><path d="M17 10L13.5 14" stroke="#5f6ff0"/>`,
  },
  ttl: {
    vb: '0 0 24 24',
    body: `<circle cx="12" cy="13" r="7"/><path d="M9 3H15"/><path d="M12 13L15 10"/><path d="M16.5 17.5L20.5 21.5" stroke="#f5634f"/><path d="M20.5 17.5L16.5 21.5" stroke="#f5634f"/>`,
  },
  ownership: {
    vb: '0 0 24 24',
    body: `<circle cx="12" cy="8" r="3.5"/><path d="M5 20C5.8 16.7 8.4 15 12 15C15.6 15 18.2 16.7 19 20"/><path d="M17.5 6.5L20 9L23 5" stroke="#15a99b" stroke-linejoin="round"/>`,
  },
  'usage-signal': {
    vb: '0 0 24 24',
    body: `<path d="M4 18V10"/><path d="M9.3 18V6"/><path d="M14.7 18V13"/><path d="M20 18V8" stroke="#5f6ff0"/><path d="M3 20H21"/>`,
  },
  'agentic-system': {
    vb: '0 0 24 24',
    body: `<rect x="5" y="7" width="14" height="11" rx="3"/><path d="M9 7V4"/><path d="M15 7V4"/><circle cx="10" cy="12.5" r="1" fill="currentColor" stroke="none"/><circle cx="14" cy="12.5" r="1" fill="currentColor" stroke="none"/><path d="M9.5 16H14.5" stroke="#f5634f"/>`,
  },
  /* ---- UI chrome (same monoline grammar) ---- */
  search: { vb: '0 0 24 24', body: `<circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21"/>` },
  'arrow-right': { vb: '0 0 24 24', body: `<path d="M4 12H19"/><path d="M13 6L19 12L13 18"/>` },
  'arrow-left': { vb: '0 0 24 24', body: `<path d="M20 12H5"/><path d="M11 6L5 12L11 18"/>` },
  'arrow-up-right': { vb: '0 0 24 24', body: `<path d="M7 17L17 7"/><path d="M8 7H17V16"/>` },
  copy: { vb: '0 0 24 24', body: `<rect x="9" y="9" width="11" height="11" rx="2.5"/><path d="M5 15.5V6A2.5 2.5 0 0 1 7.5 3.5H15"/>` },
  check: { vb: '0 0 24 24', body: `<path d="M5 12.5L10 17.5L19 7"/>` },
  share: { vb: '0 0 24 24', body: `<circle cx="6.5" cy="12" r="2.3"/><circle cx="17.5" cy="6" r="2.3"/><circle cx="17.5" cy="18" r="2.3"/><path d="M8.6 11L15.4 7.1"/><path d="M8.6 13L15.4 16.9"/>` },
  link: { vb: '0 0 24 24', body: `<path d="M10 14L14 10"/><path d="M12.6 7.4L14 6A3.5 3.5 0 0 1 19 11L17.6 12.4"/><path d="M11.4 16.6L10 18A3.5 3.5 0 0 1 5 13L6.4 11.6"/>` },
  close: { vb: '0 0 24 24', body: `<path d="M6 6L18 18"/><path d="M18 6L6 18"/>` },
};

const icon = ICONS[name] ?? ICONS.search;
const a11y = label ? { role: 'img', 'aria-label': label } : { 'aria-hidden': 'true' };
---
<svg
  width={size}
  height={size}
  viewBox={icon.vb}
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...a11y}
  set:html={icon.body}
/>
