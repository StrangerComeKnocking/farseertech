---
import { SITE, NAV } from '../consts';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<aside class="sidebar">
  <nav class="sb-nav" aria-label="Primary">
    {NAV.map((item) => {
      const itemActive = item.section ? path.startsWith(item.section) : isActive(item.href);
      return (
        <div class="sb-item">
          <a href={item.href} class={itemActive ? 'active' : ''}>
            <span class="sb-dot" aria-hidden="true"></span>{item.label}
          </a>
          {item.children && itemActive && (
            <ul class="sb-sub">
              {item.children.map((c) => (
                <li>
                  <a href={c.href} class={path === c.href ? 'active' : ''}>{c.label}</a>
                </li>
              ))}
            </ul>
          )}
        </div>
      );
    })}
  </nav>

  <div class="sb-foot">
    <p class="sb-owner">{SITE.owner}</p>
    <p class="sb-role mono-label">{SITE.role}</p>
    <a class="sb-rss" href="/rss.xml">RSS</a>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--topbar-h);
    align-self: start;
    height: calc(100vh - var(--topbar-h));
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    padding: 1.5rem 1.1rem;
    border-right: 1px solid var(--line);
  }
  .sb-nav { display: flex; flex-direction: column; gap: 0.15rem; }
  .sb-item { display: flex; flex-direction: column; }
  .sb-item > a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sb-dot {
    width: 0.4rem; height: 0.4rem; border-radius: 50%;
    background: var(--line-strong);
    transition: background 0.15s ease, transform 0.15s ease;
    flex: none;
  }
  .sb-item > a:hover { background: color-mix(in srgb, var(--ink) 5%, transparent); color: var(--ink); }
  .sb-item > a.active { color: var(--ink); font-weight: 500; background: color-mix(in srgb, var(--coral) 9%, transparent); }
  .sb-item > a.active .sb-dot { background: var(--coral); transform: scale(1.2); }

  /* Nested notes, revealed when the section is active */
  .sb-sub {
    list-style: none;
    margin: 0.1rem 0 0.35rem;
    padding: 0.1rem 0 0.1rem 1.55rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    position: relative;
  }
  .sb-sub::before {
    content: '';
    position: absolute;
    left: 0.95rem;
    top: 0.2rem;
    bottom: 0.3rem;
    width: 1px;
    background: var(--line);
  }
  .sb-sub a {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.8rem;
    line-height: 1.32;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.35rem 0.5rem;
    border-radius: 7px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sb-sub a:hover { color: var(--ink); background: color-mix(in srgb, var(--ink) 4%, transparent); }
  .sb-sub a.active { color: var(--ink); font-weight: 500; background: color-mix(in srgb, var(--coral) 8%, transparent); }

  .sb-foot { margin-top: auto; display: flex; flex-direction: column; gap: 0.1rem; }
  .sb-owner { font-weight: 600; font-size: 0.96rem; }
  .sb-role { margin-top: 0.05rem; }
  .sb-rss {
    margin-top: 0.7rem; align-self: start;
    font-family: var(--mono); font-size: var(--t-xs); letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--coral); text-decoration: none;
  }
  .sb-rss:hover { text-decoration: underline; }

  @media (max-width: 60rem) {
    .sidebar {
      position: sticky;
      top: var(--topbar-h);
      height: auto;
      flex-direction: row;
      align-items: center;
      gap: 0.3rem;
      padding: 0.45rem 0.9rem;
      border-right: none;
      border-bottom: 1px solid var(--line);
      background: color-mix(in srgb, var(--paper) 90%, transparent);
      backdrop-filter: saturate(140%) blur(8px);
      overflow-x: auto;
      scrollbar-width: none;
      z-index: 40;
    }
    .sidebar::-webkit-scrollbar { display: none; }
    .sb-foot { display: none; }
    .sb-nav { flex-direction: row; gap: 0.2rem; }
    .sb-item { flex-direction: row; }
    .sb-item > a { padding: 0.4rem 0.65rem; white-space: nowrap; }
    .sb-dot { display: none; }
    .sb-sub { display: none; } /* keep the mobile strip flat */
  }
</style>
