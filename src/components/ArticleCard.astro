---
import type { Post } from '../utils/posts';
import { postUrl, postReadingTime, postAccent } from '../utils/posts';
import { PILLARS } from '../consts';
import Icon from './Icon.astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: Post;
  variant?: 'compact' | 'highlight';
}
const { post, variant = 'compact' } = Astro.props;
const pillar = PILLARS[post.data.pillar];
const url = postUrl(post);
const rt = postReadingTime(post);
const accent = postAccent(post);
---
<article class={`card card-${variant}`} style={`--accent:${accent}`}>
  <a class="card-link" href={url}><span class="sr-only">{post.data.title}</span></a>

  <div class="card-meta mono-label">
    {variant === 'highlight' && <Icon name={pillar.icon} size={16} class="card-pico" />}
    <span class="card-pillar">{pillar.short}</span>
    <span class="card-dot">·</span>
    <span>{rt}</span>
  </div>

  <h3 class="card-title">{post.data.title}</h3>
  <p class="card-sum">{post.data.description}</p>

  <div class="card-foot">
    <FormattedDate date={post.data.date} />
    {variant === 'highlight' && (
      <span class="card-read">Read<Icon name="arrow-right" size={16} /></span>
    )}
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--r);
    padding: 1rem 1.1rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }
  .card::before {
    content: '';
    position: absolute;
    left: 0; top: 1rem; bottom: 1rem;
    width: 3px; border-radius: 3px;
    background: var(--accent);
    opacity: 0.85;
  }
  .card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }
  .card-link { position: absolute; inset: 0; border-radius: inherit; z-index: 1; }
  .card-link:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .card-meta { display: flex; align-items: center; gap: 0.4rem; color: var(--ink-soft); }
  .card-pillar { color: color-mix(in srgb, var(--accent) 65%, var(--ink)); }
  .card-dot { color: var(--faint); }
  .card-pico { color: var(--accent); }

  .card-title {
    font-size: var(--t-lg);
    font-weight: 560;
    line-height: 1.16;
    letter-spacing: -0.014em;
  }
  .card-sum {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.46;
  }
  .card-foot {
    margin-top: auto;
    padding-top: 0.3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: var(--t-2xs);
    color: var(--faint);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .card-read {
    position: relative; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.3rem;
    color: var(--accent);
    text-transform: none;
    font-size: var(--t-xs);
  }
  .card:hover .card-read :global(svg) { transform: translateX(3px); transition: transform 0.18s ease; }

  /* Compact cards keep the summary tight */
  .card-compact .card-sum {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Highlight = the weekly feature */
  .card-highlight { padding: 1.4rem 1.5rem; gap: 0.65rem; }
  .card-highlight::before { top: 1.4rem; bottom: 1.4rem; width: 4px; }
  .card-highlight .card-title { font-size: var(--t-2xl); line-height: 1.08; }
  .card-highlight .card-sum { font-size: 1.1rem; max-width: 46ch; }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>
