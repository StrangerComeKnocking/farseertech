---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---
<BaseLayout title="About" description={`About FarseerTech — a personal technical publication by ${SITE.owner}.`}>
  <section class="about">
    <p class="eyebrow mono-label">About</p>
    <h1 class="about-title">A publication about what production teaches you.</h1>

    <div class="prose">
      <p>
        <strong>FarseerTech</strong> is where I write about the parts of engineering
        that only become obvious after systems reach production scale: ownership,
        reliability, product judgment, agentic architecture, and the organizational
        machinery required to make software survive contact with reality.
      </p>
      <p>
        I'm <strong>{SITE.owner}</strong> — the owner and the voice behind it. I write
        about building hyperscale AI products, AIOps systems, agentic architecture,
        production engineering, and engineering leadership. The writing is grounded in
        real experience building and operating large-scale systems, not in slideware.
      </p>
      <p>
        It's a personal publication, not a pitch. The goal is simple: calm, senior
        engineering judgment for people building agentic products at the scale where
        mistakes get expensive — <em>seeing the production bill before it arrives</em>.
      </p>
      <p>
        New writing lands as <a href="/field-notes/ai-velocity-manufacturing-liabilities">field notes</a>.
        Follow along via <a href="/rss.xml">RSS</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .about { padding: clamp(2rem, 5vw, 3.5rem) clamp(1.4rem, 5vw, 3.5rem); max-width: 50rem; }
  .eyebrow { color: var(--coral); }
  .about-title {
    margin: 0.5rem 0 1.6rem;
    font-size: var(--t-2xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
</style>
