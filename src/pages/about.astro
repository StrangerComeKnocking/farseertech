---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { SITE, PILLARS, PILLAR_ORDER } from '../consts';
---
<BaseLayout title="About" description={`About FarseerTech — a personal technical publication by ${SITE.owner}.`}>
  <section class="about container">
    <div class="about-grid">
      <div class="about-main">
        <p class="kicker mono-label">About</p>
        <h1 class="about-title">A publication about what production teaches you.</h1>
        <div class="prose about-prose">
          <p>
            <strong>FarseerTech</strong> is where I write about the parts of engineering
            that only become obvious after systems reach production scale: ownership,
            reliability, product judgment, agentic architecture, and the organizational
            machinery required to make software survive contact with reality.
          </p>
          <p>
            I'm <strong>{SITE.owner}</strong> — the owner and the voice behind it. I write
            about building hyperscale AI products, AIOps systems, agentic architecture,
            production engineering, and engineering leadership. The writing is grounded in
            real experience building and operating large-scale systems, not in slideware.
          </p>
          <p>
            FarseerTech is a personal publication, not a pitch. The goal is simple: calm,
            senior engineering judgment for people building agentic products at the scale
            where mistakes get expensive — <em>seeing the production bill before it arrives</em>.
          </p>
        </div>
      </div>

      <aside class="about-side">
        <p class="block-label mono-label">What I write about</p>
        <ul class="about-pillars">
          {PILLAR_ORDER.map((id) => (
            <li style={`--accent:${PILLARS[id].accent}`}>
              <a href={`/${id}`}>
                <span class="ap-icon"><Icon name={PILLARS[id].icon} size={18} /></span>
                <span>
                  <span class="ap-name">{PILLARS[id].name}</span>
                  <span class="ap-blurb">{PILLARS[id].blurb}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
        <a class="about-rss" href="/rss.xml"><Icon name="arrow-right" size={15} />Follow via RSS</a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about { padding-top: clamp(2rem, 5vw, 3.4rem); }
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: start;
  }
  .kicker { color: var(--coral); }
  .about-title {
    margin: 0.5rem 0 1.2rem;
    font-size: var(--t-2xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .about-side { position: sticky; top: 5.2rem; }
  .block-label { margin-bottom: 0.7rem; }
  .about-pillars { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .about-pillars a {
    display: flex; gap: 0.6rem; align-items: flex-start;
    padding: 0.6rem 0.7rem; border: 1px solid var(--line); border-radius: var(--r);
    background: var(--card); text-decoration: none; color: var(--ink);
    transition: border-color 0.15s ease;
  }
  .about-pillars a:hover { border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); }
  .ap-icon { color: var(--accent); margin-top: 1px; }
  .ap-name { display: block; font-family: var(--serif); font-weight: 580; font-size: 0.98rem; }
  .ap-blurb { display: block; font-size: 0.8rem; color: var(--ink-soft); line-height: 1.4; margin-top: 0.1rem; }
  .about-rss {
    display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 1rem;
    font-family: var(--mono); font-size: var(--t-xs); color: var(--coral); text-decoration: none;
  }
  .about-rss:hover { text-decoration: underline; }

  @media (max-width: 52rem) {
    .about-grid { grid-template-columns: 1fr; }
    .about-side { position: static; }
  }
</style>
