---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, FEATURED } from '../consts';
const titleBefore = FEATURED.title.replace(FEATURED.highlight, '').trim();
---
<BaseLayout crumbs={[{ label: 'Home' }]}>
  <section class="home">
    <header class="home-head">
      <p class="eyebrow mono-label">FarseerTech · Field Notes</p>
      <h1 class="home-title">{SITE.positioning}</h1>
      <p class="home-tag">{SITE.tagline}</p>
    </header>

    <a class="feature" href={FEATURED.href}>
      <div class="feature-media">
        <img src={FEATURED.comic} alt="Three-panel comic: the life of an agent-built tool from ship day to an unowned 3 a.m. page." loading="eager" />
      </div>
      <div class="feature-body">
        <p class="feature-kicker mono-label">{FEATURED.series} · {FEATURED.number} · {FEATURED.kicker}</p>
        <h2 class="feature-title">{titleBefore} <span class="hl">{FEATURED.highlight}</span></h2>
        <p class="feature-dek">{FEATURED.description}</p>
        <span class="feature-cta">Read the field note <span aria-hidden="true">→</span></span>
      </div>
    </a>

    <aside class="owner">
      <img class="owner-mark" src="/icons/farseertech-circle-96.png" alt="" width="34" height="34" />
      <p class="owner-text">
        <strong>{SITE.owner}</strong> writes <a href="/about">FarseerTech</a> — the parts of engineering
        that only get obvious after systems reach production scale.
      </p>
    </aside>
  </section>
</BaseLayout>

<style>
  .home { padding: clamp(2rem, 5vw, 3.5rem) clamp(1.4rem, 5vw, 3.5rem); max-width: 64rem; }
  .home-head { max-width: 40rem; }
  .eyebrow { color: var(--coral); }
  .home-title {
    margin-top: 0.7rem;
    font-size: var(--t-2xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .home-tag {
    margin-top: 0.6rem;
    font-family: var(--mono);
    font-size: var(--t-sm);
    color: var(--ink-soft);
  }

  .feature {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(1.2rem, 3vw, 2.4rem);
    align-items: center;
    margin-top: clamp(2rem, 5vw, 3rem);
    padding: clamp(1.2rem, 2.5vw, 1.8rem);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .feature:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--coral) 35%, var(--line));
  }
  .feature-media img {
    width: 100%;
    border: 2.5px solid var(--ink);
    border-radius: 12px;
    box-shadow: var(--shadow-pop);
  }
  .feature-kicker { color: var(--ink-soft); }
  .feature-title {
    margin-top: 0.5rem;
    font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .feature-title .hl { color: var(--coral); }
  .feature-dek {
    margin-top: 0.7rem;
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 42ch;
  }
  .feature-cta {
    display: inline-flex; align-items: center; gap: 0.4rem;
    margin-top: 1.1rem;
    font-family: var(--mono); font-size: var(--t-sm); font-weight: 500;
    color: var(--coral);
  }
  .feature:hover .feature-cta span { transform: translateX(4px); transition: transform 0.2s ease; }

  .owner {
    display: flex; align-items: center; gap: 0.9rem;
    margin-top: clamp(1.8rem, 4vw, 2.6rem);
    max-width: 46rem;
  }
  .owner-mark { width: 2.1rem; height: 2.1rem; border-radius: 50%; flex: none; }
  .owner-text { font-size: 1.02rem; color: var(--ink-soft); line-height: 1.5; }
  .owner-text strong { color: var(--ink); }
  .owner-text a { color: var(--indigo); }

  @media (max-width: 48rem) {
    .feature { grid-template-columns: 1fr; }
  }
</style>
